# =============================================================================
#  .gitignore — StockSense
# =============================================================================

# ── CRITICAL: Never commit secrets ────────────────────────────────────────────
.env
*.env
.env.local
.env.production

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
env/
.venv/
.env/
ENV/

# ── Trained models (large files) ─────────────────────────────────────────────
backend/models/*.pkl
backend/models/*.joblib
backend/models/*.bin
# Keep model directory structure
!backend/models/.gitkeep

# ── Logs & exports ────────────────────────────────────────────────────────────
logs/
exports/
*.log

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Test artifacts ────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
